# Force the version of clang in the analyzer
# This was causing the static analyzer to fail silently if the clang & clang++ are
# not installed
Index: llvm-toolchain-snapshot_22~++20250422202230+f541a3aad8e7/clang/tools/scan-build/libexec/ccc-analyzer
===================================================================
--- llvm-toolchain-snapshot_22~++20250422202230+f541a3aad8e7.orig/clang/tools/scan-build/libexec/ccc-analyzer
+++ llvm-toolchain-snapshot_22~++20250422202230+f541a3aad8e7/clang/tools/scan-build/libexec/ccc-analyzer
@@ -76,7 +76,7 @@ sub silent_system {
 
 sub DetermineClang {
   my ($is_cxx) = @_;
-  my $default = $is_cxx ? 'clang++' : 'clang';
+  my $default = $is_cxx ? 'clang++-22' : 'clang-22';
   my $opt = $ENV{$is_cxx ? 'CLANG_CXX' : 'CLANG'};
   return defined $opt ? $opt : $default;
 }

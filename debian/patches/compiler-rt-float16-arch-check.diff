Description: Move FLOAT16 check to use proper target flags
 The FLOAT16 check in builtin-config-ix.cmake runs without architecture-specific
 flags, so on x86_64 host building for i386, it incorrectly detects _Float16
 support. Move the check into CMakeLists.txt where CMAKE_REQUIRED_FLAGS are
 properly set for each architecture (similar to how BFLOAT16 is checked).
Author: Debian LLVM Team
Bug: https://github.com/llvm/llvm-project/issues/XXXXX
Last-Update: 2026-01-24

Index: llvm-toolchain-22-22.1.0~+rc1/compiler-rt/cmake/builtin-config-ix.cmake
===================================================================
--- llvm-toolchain-22-22.1.0~+rc1.orig/compiler-rt/cmake/builtin-config-ix.cmake
+++ llvm-toolchain-22-22.1.0~+rc1/compiler-rt/cmake/builtin-config-ix.cmake
@@ -282,13 +282,6 @@ if(NOT APPLE)
   filter_available_targets(BUILTIN_SUPPORTED_ARCH
     ${ALL_BUILTIN_SUPPORTED_ARCH})

-  # COMPILER_RT_HAS_${arch}_* defines that are shared between lib/builtins/ and test/builtins/
-  foreach (arch ${BUILTIN_SUPPORTED_ARCH})
-    # NOTE: The corresponding check for if(APPLE) is in CompilerRTDarwinUtils.cmake
-    check_c_source_compiles("_Float16 foo(_Float16 x) { return x; }
-                              int main(void) { return 0; }"
-                            COMPILER_RT_HAS_${arch}_FLOAT16)
-  endforeach()
 endif()

 if(OS_NAME MATCHES "Linux|SerenityOS" AND NOT LLVM_USE_SANITIZER AND NOT
Index: llvm-toolchain-22-22.1.0~+rc1/compiler-rt/lib/builtins/CMakeLists.txt
===================================================================
--- llvm-toolchain-22-22.1.0~+rc1.orig/compiler-rt/lib/builtins/CMakeLists.txt
+++ llvm-toolchain-22-22.1.0~+rc1/compiler-rt/lib/builtins/CMakeLists.txt
@@ -999,6 +999,11 @@ if (NOT COMPILER_RT_BAREMETAL_BUILD)
           endif()
         endif()
       endif()
+      # Check for _Float16 support with proper target flags
+      # (moved from builtin-config-ix.cmake to ensure correct cross-compilation detection)
+      check_c_source_compiles("_Float16 foo(_Float16 x) { return x; }
+                               int main(void) { return 0; }"
+                              COMPILER_RT_HAS_${arch}_FLOAT16)
       append_list_if(COMPILER_RT_HAS_${arch}_FLOAT16 -DCOMPILER_RT_HAS_FLOAT16 BUILTIN_CFLAGS_${arch})
       check_c_source_compiles("__bf16 foo(__bf16 x) { return x; }
                                int main(void) { return 0; }"
